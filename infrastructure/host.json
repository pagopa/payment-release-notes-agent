{
  "version": "2.0",
  "functionTimeout": "00:30:00",
  "extensions": {
    "queues": {
      "visibilityTimeout": "00:25:00",
      "maxDequeueCount": 3
    }
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Host.Results": "Warning",
      "Host.Aggregator": "Warning"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  }
}
