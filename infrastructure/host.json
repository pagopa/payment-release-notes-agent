{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "functionTimeout": "00:30:00",
  "extensions": {
    "queues": {
      "visibilityTimeout": "00:25:00",
      "maxDequeueCount": 3
    }
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Host.Results": "Warning",
      "Host.Aggregator": "Warning",
      "Azure.Core": "Warning",
      "Azure.Storage": "Warning",
      "Microsoft.Azure.WebJobs.Host.Blobs": "Warning",
      "Microsoft.Azure.WebJobs.Host.Queues": "Warning",
      "Microsoft.Azure.WebJobs.Extensions.Storage": "Warning"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  }
}
