# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── LLM provider — choose one ─────────────────────────────────────────────────

# GitHub Models (Copilot) — uses your GitHub PAT, no extra API key required
LLM_PROVIDER=copilot
COPILOT_MODEL=openai/gpt-4.1
# Run `python main.py list-models` to see all available model IDs

# ── Atlassian — optional (shared credentials for JIRA and Confluence) ─────────
#Get your API token at: id.atlassian.com → Security → API tokens
ATLASSIAN_URL=https://your-org.atlassian.net
ATLASSIAN_USER=your_email@company.com
ATLASSIAN_TOKEN=your_atlassian_api_token

# ── Document generation ───────────────────────────────────────────────────────
ENVIRONMENTS=dev,uat,prod
RESPONSIBLE_TEAM=Team Infrastructure
DOCUMENT_LANGUAGE=Italian
DEPARTMENT_NAME=Payments Department

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
